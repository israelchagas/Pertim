# ─── RESEND (Email) ─────────────────────────────────────────────
RESEND_API_KEY=re_your_key                        # nunca no frontend
RESEND_FROM=oi@pertim.online

# ─── ONESIGNAL (Push Notifications) ────────────────────────────
VITE_ONESIGNAL_APP_ID=your_app_id
